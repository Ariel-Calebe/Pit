{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "./",
    "outDir": "../dist",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false,
    "types": ["node"],
    "lib": ["ES2020", "DOM"],
    "resolveJsonModule": true  
  },
  "include": ["./**/*.ts"]
}
